{
    "name": "taxinvest/backend",
    "description": "TaxInvest PHP backend",
    "type": "project",
    "require": {
        "php": "^8.4",
        "api-platform/doctrine-orm": "^4.3",
        "api-platform/symfony": "^4.3",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "lexik/jwt-authentication-bundle": "^3.2",
        "nelmio/cors-bundle": "^2.6",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpstan/phpdoc-parser": "^2.3",
        "symfony/amqp-messenger": "^8.1",
        "symfony/asset": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/flex": "^2.11",
        "symfony/framework-bundle": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/monolog-bundle": "^4.0",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/routing": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/uid": "^8.1",
        "symfony/validator": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.2",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "test": "php bin/phpunit",
        "qa": [
            "@cs-check",
            "@phpstan",
            "@test"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    }
}
